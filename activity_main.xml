<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- WebView con SwipeRefresh -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefreshLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <WebView
            android:id="@+id/webView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- Barra de progreso de carga -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_gravity="top"
        android:visibility="gone"
        android:indeterminate="false"
        android:progressTint="@color/themaro_primary"
        android:progressBackgroundTint="@color/themaro_primary_light"
        style="@android:style/Widget.ProgressBar.Horizontal" />

    <!-- Pantalla sin conexión -->
    <LinearLayout
        android:id="@+id/offlineLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:background="@color/white"
        android:visibility="gone">

        <!-- Icono de sin conexión -->
        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_no_wifi"
            android:contentDescription="Sin conexión"
            android:layout_marginBottom="24dp" />

        <!-- Logo pequeño -->
        <ImageView
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/ic_logo_themaro"
            android:scaleType="fitCenter"
            android:contentDescription="TheMaro"
            android:layout_marginBottom="24dp"
            android:alpha="0.5"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sin conexión a internet"
            android:textColor="@color/themaro_black"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Verifica tu conexión a WiFi o datos móviles para explorar TheMaro."
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginBottom="32dp"/>

        <Button
            android:id="@+id/btnRetry"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="Reintentar"
            android:textColor="@color/white"
            android:backgroundTint="@color/themaro_primary"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:textSize="15sp"
            android:textStyle="bold"
            android:stateListAnimator="@null" />

    </LinearLayout>

</FrameLayout>
