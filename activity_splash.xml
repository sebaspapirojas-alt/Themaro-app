<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/themaro_black">

    <ImageView
        android:id="@+id/splashLogo"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:src="@drawable/ic_logo_themaro"
        android:scaleType="fitCenter"
        android:contentDescription="TheMaro Logo" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TheMaro"
        android:textColor="@color/white"
        android:textSize="32sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:layout_marginTop="16dp"
        android:letterSpacing="0.15"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Wear Your Story"
        android:textColor="@color/themaro_primary"
        android:textSize="14sp"
        android:fontFamily="sans-serif-light"
        android:layout_marginTop="8dp"
        android:letterSpacing="0.1"/>

    <ProgressBar
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:indeterminateTint="@color/themaro_primary"
        style="@style/Widget.AppCompat.ProgressBar"/>

</LinearLayout>
